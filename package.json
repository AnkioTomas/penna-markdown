{
  "name": "cherry-markdown-next",
  "version": "0.1.0",
  "packageManager": "pnpm@11.5.0",
  "type": "module",
  "main": "./dist/editor.cjs",
  "module": "./dist/editor.mjs",
  "unpkg": "./dist/editor.iife.js",
  "jsdelivr": "./dist/editor.iife.js",
  "exports": {
    ".": {
      "import": "./dist/editor.mjs",
      "require": "./dist/editor.cjs",
      "default": "./dist/editor.mjs"
    },
    "./transformer": {
      "import": "./dist/transformer.mjs",
      "require": "./dist/transformer.cjs",
      "default": "./dist/transformer.mjs"
    },
    "./transformer.min": {
      "import": "./dist/transformer.min.mjs",
      "require": "./dist/transformer.min.cjs",
      "default": "./dist/transformer.min.mjs"
    },
    "./cherry-theme-*-render.css": "./dist/cherry-theme-*-render.min.css",
    "./cherry-theme-*-render.min.css": "./dist/cherry-theme-*-render.min.css",
    "./cherry-theme-*-editor.css": "./dist/cherry-theme-*-editor.min.css",
    "./cherry-theme-*-editor.min.css": "./dist/cherry-theme-*-editor.min.css",
    "./theme/*/render.css": "./dist/cherry-theme-*-render.min.css",
    "./theme/*/render.min.css": "./dist/cherry-theme-*-render.min.css",
    "./theme/*/editor.css": "./dist/cherry-theme-*-editor.min.css",
    "./theme/*/editor.min.css": "./dist/cherry-theme-*-editor.min.css",
    "./cherry-editor-base.css": "./dist/cherry-editor-base.min.css",
    "./cherry-editor-base.min.css": "./dist/cherry-editor-base.min.css",
    "./transformer.css": "./dist/cherry-theme-default-render.min.css",
    "./transformer.min.css": "./dist/cherry-theme-default-render.min.css",
    "./editor.css": "./dist/cherry-theme-default-editor.min.css",
    "./editor.min.css": "./dist/cherry-theme-default-editor.min.css",
    "./renderer": {
      "import": "./dist/renderer.mjs",
      "require": "./dist/renderer.cjs",
      "default": "./dist/renderer.mjs"
    },
    "./editor": {
      "import": "./dist/editor.mjs",
      "require": "./dist/editor.cjs",
      "default": "./dist/editor.mjs"
    },
    "./theme": {
      "import": "./dist/theme.mjs",
      "require": "./dist/theme.cjs",
      "default": "./dist/theme.mjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "build:theme": "tsx scripts/build.ts --styles-only",
    "demo": "vite --config demo/vite.config.ts --host",
    "fetch:gfm": "tsx scripts/fetch-gfm-spec.ts",
    "fetch:gfm:split": "tsx scripts/fetch-gfm-spec.ts --split",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "entities": "^6.0.1",
    "esbuild": "^0.28.0",
    "highlight.js": "11.11.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.6.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "jsdom": "^26.1.0",
    "sass": "^1.100.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^6.3.5",
    "vitest": "^2.1.8"
  }
}
